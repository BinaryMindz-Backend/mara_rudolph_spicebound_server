// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model User {
  id                String   @id @default(uuid())
  firstName         String
  email             String   @unique
  passwordHash      String
  plan              SubscriptionPlan @default(FREE)
  stripeCustomerId  String?
  createdAt         DateTime @default(now())

  // library           UserBook[]
  // ratings           Rating[]
  // subscriptions     Subscription[]
}

model Book {
  id                  String   @id @default(uuid())

  title               String
  author              String
  firstPublishedYear  Int?
  description         String?

  ageLevel            AgeLevel?
  spiceRating         Int?

  tropes              String[]
  creatures           String[]
  subgenres           String[]

  seriesName          String?
  seriesIndex         Int?
  seriesTotal         Int?
  seriesStatus        SeriesStatus?

  isbn13              String?
  googleVolumeId      String?
  openLibraryId       String?
  asin                String?

  amazonUrl           String
  bookshopUrl         String

  externalAvgRating   Float?
  externalRatingCount Int?

  spiceboundAvgRating Float?
  spiceboundRatingCount Int @default(0)

  createdAt           DateTime @default(now())

  // users               UserBook[]
  // ratings             Rating[]
}

enum AgeLevel {
  CHILDREN
  YA
  NA
  ADULT
  EROTICA
}

enum ReadingStatus {
  TBR
  READING
  READ
  DNF
}

enum SeriesStatus {
  COMPLETE
  INCOMPLETE
  UNKNOWN
}

enum SubscriptionPlan {
  FREE
  PREMIUM
}