// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../prisma/generated/prisma-client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String           @id @default(uuid())
  firstName          String                              // FIX #7: renamed from `name` to match signup spec (firstName)
  email              String           @unique
  password           String
  plan               SubscriptionPlan @default(FREE)
  stripeCustomerId   String?
  resetToken         String?
  resetTokenExpiry   DateTime?
  refreshToken       String?
  refreshTokenExpiry DateTime?
  createdAt          DateTime         @default(now())

  library       UserBook[]
  ratings       Rating[]
  subscriptions Subscription[]
}

model Book {
  id String @id @default(uuid())

  // Identity
  title            String
  normalizedTitle  String
  primaryAuthor    String
  normalizedAuthor String

  firstPublishedYear Int?

  // FIX #8: Added coverUrl for future use (Doc 1, Section 4.4)
  coverUrl String?

  // AI-enriched classification
  ageLevel               AgeLevel @default(UNKNOWN)
  spiceCategory          String?
  spiceRating            Int?     // 0-5 scale
  spiceIncreasesInSeries Boolean  @default(false)

  tropes    String[]
  creatures String[]
  subgenres String[]

  // Description
  shortDescription String?

  // Series info
  seriesName   String?
  seriesIndex  Int?
  seriesTotal  Int?
  seriesStatus SeriesStatus @default(UNKNOWN)

  // Multi-arc info
  isMultiArc   Boolean      @default(false)
  arcName      String?
  arcNumber    Int?          // FIX #4: renamed from arcIndex → arcNumber (stores which arc, e.g. 1, 2, 3)
  arcPosition  Int?          // FIX #5: new field — book's position *within* its arc (e.g. 1 of 2)
  arcTotal     Int?
  arcStatus    SeriesStatus  @default(UNKNOWN)

  // Ratings (from external sources like Google Books)
  externalAvgRating   Float?
  externalRatingCount Int?

  // Purchase links
  amazonUrl   String?
  bookshopUrl String?

  // FIX #2: AI confidence levels — persisted so low-confidence records can be flagged for review
  confidenceSpiceRating String?   // "HIGH" | "MEDIUM" | "LOW"
  confidenceOverall     String?   // "HIGH" | "MEDIUM" | "LOW"

  // Relations
  aliases BookAlias[]
  users   UserBook[]
  ratings Rating[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([normalizedTitle, normalizedAuthor])
}

model BookAlias {
  id String @id @default(uuid())

  type  BookAliasType
  value String

  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([type, value])
  @@index([value])
}

model UserBook {
  id String @id @default(uuid())

  userId String
  bookId String

  status     ReadingStatus @default(TBR)
  orderIndex Int           @default(0)    // FIX #6: added default to prevent runtime errors on create
  rating     Float?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
}

model Rating {
  id     String @id @default(uuid())
  userId String
  bookId String
  value  Float

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
}

model Subscription {
  id                   String           @id @default(uuid())   // FIX: changed cuid() to uuid() for consistency
  userId               String
  stripeCustomerId     String
  stripeSubscriptionId String
  plan                 SubscriptionPlan
  status               String
  billingInterval      String?
  expiresAt            DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// FIX #1: Renamed CHILDREN → CHILDRENS to match AI prompt output and sanitizer normalization
enum AgeLevel {
  CHILDRENS
  YA
  NA
  ADULT
  EROTICA
  UNKNOWN
}

enum ReadingStatus {
  TBR
  READING
  READ
  DNF
}

enum BookAliasType {
  ISBN_10
  ISBN_13
  GOOGLE_VOLUME_ID
  OPEN_LIBRARY_ID
  ASIN
  GOODREADS_ID
}

enum SeriesStatus {
  COMPLETE
  INCOMPLETE
  UNKNOWN
}

enum SubscriptionPlan {
  FREE
  PREMIUM
}