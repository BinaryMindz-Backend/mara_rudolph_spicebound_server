# -------------------------------------------------------------------
# Server Configuration
# -------------------------------------------------------------------

# Port on which the backend server will run
PORT=

# Public site URL (used for redirects, SEO, emails, etc.)
SITE_URL=

# Frontend application URL
FRONTEND_URL=


# -------------------------------------------------------------------
# Database Configuration
# -------------------------------------------------------------------

# PostgreSQL connection string
# Example (local): postgresql://user:password@localhost:5432/db_name
# Example (docker): postgresql://user:password@postgres:5432/db_name
DATABASE_URL=


# -------------------------------------------------------------------
# External Book & Data APIs
# -------------------------------------------------------------------
GOOGLE_BOOKS_KEY=
OPEN_LIBRARY=


# -------------------------------------------------------------------
# AI / OpenAI Configuration
# -------------------------------------------------------------------
OPENAI_KEY=


# -------------------------------------------------------------------
# Stripe Payment Configuration
# -------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=


# -------------------------------------------------------------------
# Authentication / JWT Configuration
# -------------------------------------------------------------------
JWT_ACCESS_SECRET=
JWT_EXPIRES_IN=


# -------------------------------------------------------------------
# Email / SMTP Configuration
# -------------------------------------------------------------------
MAIL_SERVICE=
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=
