# Docker Configuration
DOCKER_USERNAME=softvence
PACKAGE_NAME=spicebound
PACKAGE_VERSION=latest

# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/spicebound_db?schema=public"
DB_PORT=5432

# Server Configuration
PORT=5050
NODE_ENV=development
SITE_URL=https://www.readspicebound.com
BASE_URL=http://localhost:5050

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# External APIs
GOOGLE_BOOKS_KEY=your_google_books_api_key
OPEN_LIBRARY=https://openlibrary.org/search.json?title={{ encodeURI(gb_title) }}&author={{ encodeURI(gb_author) }}&limit=1
OPENAI_KEY=your_openai_api_key

# Stripe Configuration
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_PRICE_PRO_MONTHLY=price_id_monthly
STRIPE_PRICE_PRO_YEARLY=price_id_yearly

# JWT Configuration
JWT_ACCESS_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=24h

# Email Configuration
MAIL_SERVICE=gmail
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=your_email@gmail.com
FRONTEND_URL=http://localhost:3000
