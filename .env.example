# -------------------------------------------------------------------
# Server Configuration
# -------------------------------------------------------------------

# Port on which the backend server will run
PORT=5050

# Public site URL (used for redirects, SEO, emails, etc.)
SITE_URL=https://readspicebound.com

# Frontend application URL
FRONTEND_URL=http://localhost:3000


# -------------------------------------------------------------------
# Database Configuration
# -------------------------------------------------------------------

# PostgreSQL connection string
# Example (local): postgresql://user:password@localhost:5432/db_name
# Example (docker): postgresql://user:password@postgres:5434/db_name
DATABASE_URL=postgresql://spicebound:spicebound123@localhost:5434/spicebound_db?schema=public


# -------------------------------------------------------------------
# External Book & Data APIs
# -------------------------------------------------------------------
GOOGLE_BOOKS_KEY=
OPEN_LIBRARY=https://openlibrary.org/search.json


# -------------------------------------------------------------------
# AI / OpenAI Configuration
# -------------------------------------------------------------------
OPENAI_KEY=


# -------------------------------------------------------------------
# Stripe Payment Configuration
# -------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_PRICE_PRO_MONTHLY=price_
STRIPE_PRICE_PRO_YEARLY=price_
STRIPE_WEBHOOK_SECRET=whsec_


# -------------------------------------------------------------------
# Authentication / JWT Configuration
# -------------------------------------------------------------------
JWT_ACCESS_SECRET=your_super_secret_key_change_in_production
JWT_EXPIRES_IN=24h


# -------------------------------------------------------------------
# Email Configuration (Optional - for password reset)
# -------------------------------------------------------------------
MAIL_SERVICE=gmail
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@readspicebound.com

JWT_EXPIRES_IN=


# -------------------------------------------------------------------
# Email / SMTP Configuration
# -------------------------------------------------------------------
MAIL_SERVICE=
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=
